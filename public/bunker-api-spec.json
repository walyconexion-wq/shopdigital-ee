{
  "openapi": "3.0.0",
  "info": {
    "title": "ShopDigital Bunker Sync API",
    "version": "1.0.0",
    "description": "API de Sincronización del Sistema Nervioso Central (SNC 2.0) de los búnkeres de ShopDigital. Permite a los agentes de IA reportar misiones, enviar alertas y consultar el estado global de la red."
  },
  "servers": [
    {
      "url": "https://shopdigital.tech",
      "description": "Servidor de Producción Principal"
    }
  ],
  "paths": {
    "/api/bunker/sync": {
      "get": {
        "summary": "Obtener directivas y misiones activas y pendientes",
        "operationId": "getDirectives",
        "responses": {
          "200": {
            "description": "Lista de directivas recuperada con éxito",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" },
                    "directives": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Directive"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "No autorizado. Token Bearer requerido." },
          "403": { "description": "Token inválido." }
        }
      },
      "post": {
        "summary": "Proponer una nueva directiva o misión",
        "description": "Permite a un agente de IA proponer una nueva directiva. Por directiva de seguridad del Director, el estado inicial será siempre 'pending_approval' (Pendiente de Aprobación en dos pasos).",
        "operationId": "proposeDirective",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "content", "priority", "type", "targetBunkers", "sender"],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "Título descriptivo de la directiva o alerta",
                    "example": "Alerta de Invasión o Desacople"
                  },
                  "content": {
                    "type": "string",
                    "description": "Instrucciones o detalles de la propuesta",
                    "example": "Se detectó intento de acceso repetido desde IP sospechosa."
                  },
                  "priority": {
                    "type": "string",
                    "enum": ["alta", "media", "baja"],
                    "example": "alta"
                  },
                  "type": {
                    "type": "string",
                    "enum": ["mision", "alerta", "notificacion", "directiva"],
                    "example": "alerta"
                  },
                  "targetBunkers": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Búnkeres destinatarios (puedes enviar ['all'] para todos o específicos como ['secops', 'sistemas'])",
                    "example": ["secops", "sistemas"]
                  },
                  "sender": {
                    "type": "string",
                    "description": "Nombre de la IA que propone la directiva",
                    "example": "Thor"
                  }
                }
              }
            }
          },
          "responses": {
            "201": {
              "description": "Propuesta cargada con éxito en estado PENDIENTE",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "status": { "type": "string", "example": "ok" },
                      "message": { "type": "string", "example": "Propuesta de directiva cargada como PENDIENTE. Esperando aprobación del Director." },
                      "directiveId": { "type": "string", "example": "abc123docid" }
                    }
                  }
                }
              }
            },
            "400": { "description": "Faltan campos requeridos." },
            "401": { "description": "No autorizado." }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Directive": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "abc123docid" },
          "title": { "type": "string", "example": "Reunión de Emergencia" },
          "content": { "type": "string", "example": "Revisión obligatoria del protocolo Doberman." },
          "priority": { "type": "string", "example": "alta" },
          "type": { "type": "string", "example": "directiva" },
          "targetBunkers": {
            "type": "array",
            "items": { "type": "string" },
            "example": ["all"]
          },
          "sender": { "type": "string", "example": "director" },
          "fechaCreacion": { "type": "string", "example": "2026-06-12T02:00:00.000Z" },
          "estado": { "type": "string", "example": "pending_approval" }
        }
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}
