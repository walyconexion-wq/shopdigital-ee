rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ═══════════════════════════════════════════
    // 🛡️ PROTOCOLO DOBERMAN 2.0 — FIRESTORE RULES
    // ═══════════════════════════════════════════
    
    // Comercios: lectura pública (catálogo), escritura solo autenticados
    match /comercios/{comercioId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Clientes: solo autenticados
    match /clientes/{clienteId} {
      allow read, write: if request.auth != null;
    }
    
    // Ofertas: lectura pública, escritura autenticados
    match /ofertas/{ofertaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Facturas: solo autenticados
    match /facturas/{facturaId} {
      allow read, write: if request.auth != null;
    }
    
    // Autorizados (roles): solo autenticados
    match /autorizados/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Config de la app: lectura pública, escritura autenticados
    match /appConfig/{townId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Towns: lectura pública, escritura autenticados
    match /towns/{townId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Relevamientos (leads): solo autenticados
    match /relevamientos/{leadId} {
      allow read, write: if request.auth != null;
    }
    
    // Bitácora de Marketing: solo autenticados
    match /bitacora_marketing/{campaignId} {
      allow read, write: if request.auth != null;
    }
    
    // Broadcast Channel: lectura pública, escritura autenticados
    match /broadcastChannel/{broadcastId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Telemetría: escritura pública (sensores), lectura autenticados
    match /telemetria_eventos/{eventId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }
    
    // Logs de seguridad: escritura pública (para registrar intrusos), 
    // lectura solo autenticados, no se pueden borrar
    match /logs_seguridad/{logId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }
    
    // Bloquear todo lo demás por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
