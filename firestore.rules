rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ═══════════════════════════════════════════
    // 🛡️ PROTOCOLO DOBERMAN 2.0 — FIRESTORE RULES
    // ═══════════════════════════════════════════
    
    // Comercios: lectura pública (catálogo), creación pública (restringida a inactivos para aprobación) o autenticados (siembra/admin), edición solo autenticados
    match /comercios/{comercioId} {
      allow read: if true;
      allow create: if request.auth != null || request.resource.data.isActive == false;
      allow update, delete: if request.auth != null;
    }
    
    // Clientes: creación pública (para registro VIP), lectura/edición solo autenticados
    match /clientes/{clienteId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
    
    // Ofertas: lectura pública, escritura autenticados
    match /ofertas/{ofertaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Facturas: solo autenticados
    match /facturas/{facturaId} {
      allow read, write: if request.auth != null;
    }
    
    // Autorizados (roles): solo autenticados
    match /autorizados/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Config de la app: lectura pública, escritura autenticados
    match /appConfig/{townId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Towns: lectura pública, escritura autenticados
    match /towns/{townId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Relevamientos (leads): solo autenticados
    match /relevamientos/{leadId} {
      allow read, write: if request.auth != null;
    }
    
    // Bitácora de Marketing: solo autenticados
    match /bitacora_marketing/{campaignId} {
      allow read, write: if request.auth != null;
    }
    
    // Broadcast Channel: lectura pública, escritura autenticados
    match /broadcastChannel/{broadcastId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Telemetría: escritura pública (sensores), lectura autenticados
    match /telemetria_eventos/{eventId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }
    
    // Logs de seguridad (Doberman): escritura pública, lectura autenticados
    match /logs_seguridad/{logId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }
    
    // SecurityLogs (Doberman v2): escritura pública, lectura/borrado autenticados
    match /securityLogs/{logId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    
    // Reclutamiento de embajadores: lectura y escritura pública para formularios
    match /reclutamiento/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Bunker Notes (BTU): solo autenticados
    match /bunker_notes/{noteId} {
      allow read, write: if request.auth != null;
    }

    // Bunker Messages (Frecuencia Directiva): solo autenticados
    match /bunker_messages/{msgId} {
      allow read, write: if request.auth != null;
    }

    // Matriz de Sincronía (SNC Nivel 3): solo autenticados
    match /matriz_sincronia/{msgId} {
      allow read, write: if request.auth != null;
    }

    // Bunker Directives (SNC): lectura pública, creación por autenticados o API (solo pending_approval), edición/borrado solo autenticados
    match /bunker_directives/{directiveId} {
      allow read: if true;
      allow create: if request.auth != null || request.resource.data.estado == "pending_approval";
      allow update, delete: if request.auth != null;
    }

    // Eventos Live: lectura pública, escritura autenticados
    match /eventos_live/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Regiones: lectura pública, escritura autenticados
    match /regiones/{regionId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      match /{allPaths=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Telemetría de Visitas: escritura pública (sensores), lectura autenticados
    match /telemetria_visitas/{visitId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // Subcolección de créditos por comercio
    match /comercios/{comercioId}/credit_logs/{logId} {
      allow read, write: if request.auth != null;
    }
  }
}
